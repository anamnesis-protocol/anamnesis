# Normalize line endings to LF in the repo; checkout as-is on all platforms
* text=auto eol=lf

# Force LF for these types regardless
*.py text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.toml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.sh text eol=lf

# Binaries — no line ending conversion
*.png binary
*.jpg binary
*.ico binary
*.icns binary
*.pdf binary
*.wasm binary
