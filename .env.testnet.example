# .env.testnet.example — Copy to .env.testnet and fill in your testnet credentials.
# Get a free testnet account at https://portal.hedera.com (starts with 10,000 HBAR).

HEDERA_NETWORK=testnet

# Testnet operator (your account from portal.hedera.com)
OPERATOR_ID=0.0.XXXXX
OPERATOR_KEY=302e...

# Treasury can be the same account for testnet demos
TREASURY_ID=0.0.XXXXX
TREASURY_KEY=302e...

# Filled in automatically by scripts/init_testnet.py — leave as placeholders until then
HCS_TOPIC_ID=0.0.XXXXX
VALIDATOR_CONTRACT_ID=0.0.XXXXX
