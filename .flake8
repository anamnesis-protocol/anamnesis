[flake8]
max-line-length = 100
extend-ignore = E203, W503, E501, E402, C901
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    .eggs,
    *.egg,
    build,
    dist,
    .pytest_cache,
    htmlcov
per-file-ignores =
    __init__.py:F401
    # Tests: allow unused imports (mocking scaffolding), f-strings, redefinitions
    tests/*.py:F401,F541,F841,F811,E401,W293
    # Scripts: allow sys.path manipulation, unused helpers, print-style f-strings
    scripts/*.py:F401,F541,F841,F811
    # Src: allow unused imports kept for re-export / conditional SDK imports
    src/*.py:F401,F541,F841
max-complexity = 15
